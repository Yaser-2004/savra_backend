generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PPTJob {
  id         String   @id @default(cuid())
  topic      String
  grade      Int
  slides     Int
  status     String
  pptPath    String?
  cached     Boolean  @default(false)
  createdAt  DateTime @default(now())
}